# Copie para secrets.toml e preencha seus valores
# NUNCA commitar secrets.toml!

SUPABASE_URL = "https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_KEY = "your-supabase-publishable-key-here"

[users]

[users.admin]
# Use a bcrypt hash instead of plaintext. Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
password = "$2b$12$EXAMPLE_HASH_REPLACE_ME"
role = "admin"
nome = "Administrador"

[users.operador1]
password = "$2b$12$EXAMPLE_HASH_REPLACE_ME"
role = "user"
nome = "Operador 1"
