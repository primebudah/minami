# =========================================================
# IMPORTS
# =========================================================

from datetime import date
import re

import pandas as pd
import streamlit as st

from database import inicializar_banco, salvar_cliente, listar_clientes
from ocr_service import extrair_dados_do_documento, converter_data_japonesa, traduzir_veiculo
from ui_base import inject_base_css

# =========================================================
# CONFIG
# =========================================================

st.set_page_config("Registros — Minami Service", layout="wide", initial_sidebar_state="collapsed")
inject_base_css()

inicializar_banco()

st.markdown("""
<style>
[data-testid="stSidebar"] { display: none !important; }
[data-testid="stSidebar"] {
    background: linear-gradient(160deg, #0d2a6e 0%, #1044b5 60%, #0a1f5c 100%) !important;
}
